<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Stock Alert Dashboard</title>
  <style>
    :root {
      --bg: #0f172a;
      --panel: #111827;
      --text: #e5e7eb;
      --muted: #94a3b8;
      --ok: #22c55e;
      --ko: #ef4444;
      --unknown: #64748b;
      --link: #38bdf8;
    }

    body {
      margin: 0;
      font-family: Inter, system-ui, -apple-system, sans-serif;
      background: linear-gradient(180deg, #020617, var(--bg));
      color: var(--text);
      padding: 24px;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    h1 {
      margin: 0;
      font-size: 1.8rem;
    }

    .subtitle {
      color: var(--muted);
      margin: 6px 0 24px;
    }

    .product {
      background: rgba(17, 24, 39, 0.8);
      border: 1px solid #1e293b;
      border-radius: 14px;
      margin-bottom: 16px;
      overflow: hidden;
    }

    .product-header {
      padding: 14px 16px;
      background: #0b1220;
      border-bottom: 1px solid #1e293b;
      font-weight: 600;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    th, td {
      text-align: left;
      padding: 12px 16px;
      border-bottom: 1px solid #1f2937;
      vertical-align: top;
    }

    th {
      color: var(--muted);
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    tr:last-child td {
      border-bottom: none;
    }

    .status {
      font-weight: 600;
    }

    .status.ok { color: var(--ok); }
    .status.ko { color: var(--ko); }
    .status.unknown { color: var(--unknown); }
    .status.blocked { color: #f97316; }

    a {
      color: var(--link);
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    .note {
      color: var(--muted);
      font-size: 0.85rem;
      margin-top: 4px;
    }

    .pill {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 999px;
      border: 1px solid #334155;
      color: var(--muted);
      font-size: 0.8rem;
    }

    @media (max-width: 860px) {
      table, thead, tbody, th, td, tr {
        display: block;
      }
      thead {
        display: none;
      }
      td {
        padding: 10px 16px;
      }
      td::before {
        content: attr(data-label) ": ";
        color: var(--muted);
        display: inline-block;
        min-width: 110px;
      }
    }
  </style>
</head>
<body>
<div class="container">
  <h1>Stock Alert Dashboard</h1>
  <div class="subtitle">Derniere mise a jour: {{ generated_at }}</div>

  {% for product_name, rows in grouped_results.items() %}
  <section class="product">
    <div class="product-header">{{ product_name }}</div>
    <table>
      <thead>
      <tr>
        <th>Site</th>
        <th>Statut</th>
        <th>Prix</th>
        <th>Titre detecte</th>
        <th>Lien</th>
      </tr>
      </thead>
      <tbody>
      {% for row in rows %}
      {% set status_class = 'unknown' %}
      {% if row.in_stock is sameas true %}
      {% set status_class = 'ok' %}
      {% elif row.in_stock is sameas false %}
      {% set status_class = 'ko' %}
      {% elif row.availability == 'Accès bloqué' %}
      {% set status_class = 'blocked' %}
      {% endif %}
      <tr>
        <td data-label="Site">{{ row.site_icon }} {{ row.site_label }}</td>
        <td data-label="Statut" class="status {{ status_class }}">{{ row.status_emoji }} {{ row.availability }}</td>
        <td data-label="Prix">
          {% if row.price %}
            <span class="pill">{{ row.price }} {{ row.currency or '' }}</span>
          {% else %}
            -
          {% endif %}
        </td>
        <td data-label="Titre detecte">
          {{ row.title or '-' }}
          {% if row.notes %}
            <div class="note">{{ row.notes | join(' | ') }}</div>
          {% endif %}
        </td>
        <td data-label="Lien"><a href="{{ row.target_url }}" target="_blank" rel="noopener noreferrer">Voir la fiche produit</a></td>
      </tr>
      {% endfor %}
      </tbody>
    </table>
  </section>
  {% endfor %}
</div>
</body>
</html>

